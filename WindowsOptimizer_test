#region [ELEVACION]
$ErrorActionPreference = 'Continue'
$global:ScriptVersion = "7.2"

function Test-AdminElevation {
    $currentPrincipal = New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())
    $isAdmin = $currentPrincipal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
    
    if (-not $isAdmin) {
        Write-Host "Se requieren privilegios de administrador. Solicitando elevacion..." -ForegroundColor Yellow
        $scriptPath = $PSCommandPath
        if (-not $scriptPath -or $scriptPath -eq "") {
            $scriptPath = $MyInvocation.MyCommand.Definition
        }
        $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$scriptPath`""
        $process = Start-Process -FilePath "PowerShell.exe" -ArgumentList $arguments -Verb RunAs -PassThru
        $process.WaitForExit()
        exit
    }
    Write-Host "Ejecutando con privilegios de administrador..." -ForegroundColor Green
    return $true
}

Test-AdminElevation

# Detectar version de Windows
$global:WindowsVersion = (Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion").ProductName
$global:WindowsBuild = [Environment]::OSVersion.Version.Build
$global:IsWindows11 = $global:WindowsBuild -ge 22000
$global:Is24H2 = $global:WindowsBuild -ge 26100

# Crear directorio de logs
$global:LogDir = "C:\Temp\WindowsOptimizer"
$global:LogFile = "$global:LogDir\optimizer_log.txt"
New-Item -Path $global:LogDir -ItemType Directory -Force | Out-Null
if (Test-Path $global:LogFile) { Remove-Item $global:LogFile -Force }

# Variables UI
$global:LogTextBox = $null
$global:InstallRunning = $false

function Write-Log {
    param([string]$Message, [string]$Type = "INFO")
    $timestamp = Get-Date -Format "HH:mm:ss"
    $logEntry = "[$timestamp] [$Type] $Message`r`n"
    Add-Content -Path $global:LogFile -Value $logEntry -Encoding UTF8
    Write-Host $logEntry -NoNewline
    if ($global:LogTextBox -and !$global:LogTextBox.IsDisposed) {
        $global:LogTextBox.AppendText($logEntry)
        $global:LogTextBox.ScrollToCaret()
        [System.Windows.Forms.Application]::DoEvents()
    }
}
#endregion

#region [FUNCIONES DE LIMPIEZA]
function Clear-CurrentUserTemp {
    Write-Log "========== LIMPIANDO PERFIL ACTUAL ==========" "TASK"
    try {
        if (Test-Path "$env:TEMP") {
            Get-ChildItem "$env:TEMP" -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
            Write-Log "Limpieza de Temp completada" "OK"
        }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-AllUsersTemp {
    Write-Log "========== LIMPIANDO TODOS LOS PERFILES ==========" "TASK"
    Get-ChildItem "C:\Users" -Directory -EA 0 | ForEach-Object {
        $userTemp = Join-Path $_.FullName "AppData\Local\Temp"
        if (Test-Path $userTemp) {
            Write-Log "Limpiando: $($_.Name)" "INFO"
            Get-ChildItem $userTemp -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        }
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-WindowsTemp {
    Write-Log "========== LIMPIANDO WINDOWS TEMP ==========" "TASK"
    if (Test-Path "C:\Windows\Temp") {
        Get-ChildItem "C:\Windows\Temp" -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        Write-Log "Limpieza completada" "OK"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-InternetCache {
    Write-Log "========== LIMPIANDO CACHE DE INTERNET ==========" "TASK"
    try {
        Write-Log "Limpiando cache de Internet Explorer..." "INFO"
        Start-Process -FilePath "RunDll32.exe" -ArgumentList "InetCpl.cpl,ClearMyTracksByProcess 8" -NoNewWindow -Wait
        Write-Log "  ✓ Cache de IE eliminada" "OK"
    } catch {
        Write-Log "  ✗ Error limpiando cache de IE" "WARN"
    }
    
    $cachePaths = @(
        "$env:LOCALAPPDATA\Microsoft\Windows\INetCache",
        "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Cache",
        "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Cache"
    )
    foreach ($path in $cachePaths) {
        if (Test-Path $path) {
            Write-Log "Limpiando: $path" "INFO"
            Get-ChildItem $path -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        }
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Run-DiskCleanup {
    Write-Log "========== EJECUTANDO LIMPIEZA DE DISCO ==========" "TASK"
    try {
        if (Get-Command cleanmgr.exe -ErrorAction SilentlyContinue) {
            cleanmgr.exe /sagerun:64 2>&1 | Out-Null
            Write-Log "  ✓ Limpieza de disco completada" "OK"
        } else {
            Write-Log "  ✗ cleanmgr.exe no encontrado" "WARN"
        }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Disable-Firewall {
    Write-Log "========== DESHABILITANDO FIREWALL ==========" "TASK"
    try {
        netsh advfirewall set domainprofile state off | Out-Null
        netsh advfirewall set privateprofile state off | Out-Null
        netsh advfirewall set publicprofile state off | Out-Null
        Write-Log "  ✓ Firewall deshabilitado" "OK"
    } catch {
        Write-Log "Error deshabilitando firewall: $_" "ERROR"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-WindowsUpdateCache {
    Write-Log "========== LIMPIANDO CACHE DE WINDOWS UPDATE ==========" "TASK"
    try {
        Write-Log "Deteniendo servicios..." "INFO"
        net stop bits /y | Out-Null
        net stop wuauserv /y | Out-Null
        net stop cryptsvc /y | Out-Null
        Write-Log "  ✓ Servicios detenidos" "OK"
        
        Write-Log "Limpiando carpetas..." "INFO"
        @("$env:SystemRoot\SoftwareDistribution", "$env:SystemRoot\system32\catroot2") | ForEach-Object {
            if (Test-Path $_) { 
                Remove-Item "$_\*" -Recurse -Force -EA 0
                Write-Log "  ✓ Limpiado: $_" "OK"
            }
        }
        
        Write-Log "Reiniciando servicios..." "INFO"
        net start bits | Out-Null
        net start wuauserv | Out-Null
        net start cryptsvc | Out-Null
        Write-Log "  ✓ Servicios reiniciados" "OK"
    } catch {
        Write-Log "Error: $_" "ERROR"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Register-DLLs {
    Write-Log "========== REGISTRANDO DLLS DEL SISTEMA ==========" "TASK"
    $dlls = @(
        "atl.dll", "urlmon.dll", "mshtml.dll", "shdocvw.dll", "browseui.dll",
        "jscript.dll", "vbscript.dll", "scrrun.dll", "msxml.dll", "msxml3.dll",
        "msxml6.dll", "actxprxy.dll", "softpub.dll", "wintrust.dll", "dssenh.dll",
        "rsaenh.dll", "gpkcsp.dll", "sccbase.dll", "slbcsp.dll", "cryptdlg.dll",
        "oleaut32.dll", "ole32.dll", "shell32.dll", "initpki.dll", "wuapi.dll",
        "wuaueng.dll", "wuaueng1.dll", "wucltui.dll", "wups.dll", "wups2.dll",
        "wuweb.dll", "qmgr.dll", "qmgrprxy.dll"
    )
    
    Push-Location "$env:windir\system32"
    foreach ($dll in $dlls) {
        try {
            if (Test-Path $dll) {
                regsvr32.exe /s $dll
                Write-Log "  ✓ Registrado: $dll" "OK"
            }
        } catch {
            Write-Log "  ✗ Error registrando: $dll" "WARN"
        }
    }
    Pop-Location
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Invoke-FullCleanup {
    Write-Log "========== LIMPIEZA COMPLETA DEL SISTEMA ==========" "TASK"
    Clear-CurrentUserTemp
    Clear-AllUsersTemp
    Clear-WindowsTemp
    Clear-InternetCache
    Run-DiskCleanup
    Disable-Firewall
    Clear-WindowsUpdateCache
    Register-DLLs
    Write-Log "========== LIMPIEZA COMPLETA FINALIZADA ==========" "OK"
    Write-Log "Se recomienda reiniciar el sistema." "INFO"
}
#endregion

#region [FUNCIONES DE DEBLOAT]
function Remove-AllBloatware {
    Write-Log "========== ELIMINANDO BLOATWARE ==========" "TASK"
    $removed = 0
    
    $bloatware = @(
        "Microsoft.BingNews", "Microsoft.BingWeather", "Microsoft.GetHelp", "Microsoft.Getstarted",
        "Microsoft.Microsoft3DViewer", "Microsoft.MicrosoftOfficeHub", "Microsoft.MicrosoftSolitaireCollection",
        "Microsoft.MixedReality.Portal", "Microsoft.Office.OneNote", "Microsoft.People", "Microsoft.Print3D",
        "Microsoft.SkypeApp", "Microsoft.WindowsAlarms", "Microsoft.WindowsFeedbackHub", "Microsoft.WindowsMaps",
        "Microsoft.Xbox.TCUI", "Microsoft.XboxApp", "Microsoft.XboxGameOverlay", "Microsoft.XboxGamingOverlay",
        "Microsoft.XboxIdentityProvider", "Microsoft.YourPhone", "Microsoft.ZuneMusic", "Microsoft.ZuneVideo",
        "CandyCrush", "Facebook", "Twitter", "Spotify", "Netflix", "Disney",
        "Microsoft.Advertising.Xaml", "Microsoft.MSPaint", "Microsoft.Todos", "Microsoft.PowerAutomateDesktop",
        "Microsoft.Windows.DevHome", "Microsoft.Windows.Photos", "Microsoft.Windows.ScreenSketch",
        "Microsoft.WindowsSoundRecorder", "Microsoft.OutlookForWindows", "Microsoft.Clipchamp.Clipchamp"
    )
    
    if ($global:IsWindows11) {
        $bloatware += @("Microsoft.Copilot", "Microsoft.Windows.AI.Copilot")
    }
    
    $bloatwareRegex = $bloatware -join '|'
    
    Write-Log "Eliminando paquetes de usuario..." "INFO"
    Get-AppxPackage | Where-Object { $_.Name -match $bloatwareRegex } | ForEach-Object {
        try {
            Remove-AppxPackage -Package $_ -EA 0
            $removed++
            Write-Log "  ✓ Eliminado: $($_.Name)" "OK"
        } catch {
            Write-Log "  ✗ Error: $($_.Name)" "WARN"
        }
    }
    
    Write-Log "Eliminando paquetes provisionados..." "INFO"
    Get-AppxProvisionedPackage -Online | Where-Object { $_.DisplayName -match $bloatwareRegex } | ForEach-Object {
        try {
            Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -EA 0
            $removed++
            Write-Log "  ✓ Eliminado provisionado: $($_.DisplayName)" "OK"
        } catch {
            Write-Log "  ✗ Error: $($_.DisplayName)" "WARN"
        }
    }
    
    Write-Log "========== COMPLETADO: $removed apps eliminadas ==========" "OK"
}

function Disable-Copilot {
    Write-Log "========== DESACTIVANDO COPILOT ==========" "TASK"
    
    if (-not $global:IsWindows11) {
        Write-Log "Copilot solo existe en Windows 11. No hay nada que desactivar." "WARN"
        Write-Log "========== COMPLETADO ==========" "OK"
        return
    }
    
    $removed = 0
    
    Write-Log "Eliminando paquetes de Copilot..." "INFO"
    Get-AppxPackage | Where-Object { $_.Name -match "Copilot|Microsoft.Windows.AI.Copilot|Microsoft.Copilot" } | ForEach-Object {
        try {
            Remove-AppxPackage -Package $_ -EA 0
            $removed++
            Write-Log "  ✓ Eliminado: $($_.Name)" "OK"
        } catch {
            Write-Log "  ✗ Error: $($_.Name)" "WARN"
        }
    }
    
    Write-Log "Eliminando paquetes provisionados de Copilot..." "INFO"
    Get-AppxProvisionedPackage -Online | Where-Object { $_.DisplayName -match "Copilot|Microsoft.Windows.AI.Copilot|Microsoft.Copilot" } | ForEach-Object {
        try {
            Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -EA 0
            $removed++
            Write-Log "  ✓ Eliminado provisionado: $($_.DisplayName)" "OK"
        } catch {
            Write-Log "  ✗ Error: $($_.DisplayName)" "WARN"
        }
    }
    
    Write-Log "Desactivando Copilot en el registro..." "INFO"
    try {
        $regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot"
        if (!(Test-Path $regPath)) { New-Item $regPath -Force | Out-Null }
        Set-ItemProperty -Path $regPath -Name "TurnOffWindowsCopilot" -Value 1 -EA 0
        Write-Log "  ✓ Copilot desactivado en registro" "OK"
    } catch {
        Write-Log "  ✗ Error en registro" "WARN"
    }
    
    Write-Log "Reiniciando explorador..." "INFO"
    try {
        Stop-Process -Name explorer -Force -EA 0
        Start-Sleep -Seconds 2
        Start-Process explorer.exe
        Write-Log "  ✓ Explorador reiniciado" "OK"
    } catch {
        Write-Log "  ✗ Error al reiniciar explorador" "WARN"
    }
    
    Write-Log "========== COMPLETADO: $removed elementos eliminados ==========" "OK"
    Write-Log "Se recomienda reiniciar el sistema." "INFO"
}
#endregion

#region [FUNCIONES DE INSTALACIÓN]
function Install-SelectedApps {
    param([string[]]$Apps)
    if ($global:InstallRunning) { Write-Log "Ya hay una instalacion en curso" "WARN"; return }
    $global:InstallRunning = $true
    Write-Log "========== INSTALANDO APLICACIONES ==========" "TASK"
    
    # Verificar Winget
    $wingetAvailable = $false
    try {
        if (Get-Command winget -ErrorAction SilentlyContinue) {
            $wingetAvailable = $true
        }
    } catch { }
    
    if (-not $wingetAvailable) { 
        Write-Log "Winget no disponible. Abriendo páginas de descarga..." "WARN"
        foreach ($app in $Apps) {
            switch ($app) {
                "7zip" { Start-Process "https://www.7-zip.org/" }
                "Chrome" { Start-Process "https://www.google.com/chrome/" }
                "Firefox" { Start-Process "https://www.mozilla.org/firefox/" }
                "VLC" { Start-Process "https://www.videolan.org/vlc/" }
            }
        }
        $global:InstallRunning = $false
        return
    }
    
    foreach ($app in $Apps) {
        Write-Log "Instalando: $app..." "INFO"
        try {
            switch ($app) {
                "7zip" { winget install --id 7zip.7zip --silent --accept-package-agreements --accept-source-agreements }
                "Chrome" { winget install --id Google.Chrome --silent --accept-package-agreements --accept-source-agreements }
                "Firefox" { winget install --id Mozilla.Firefox --silent --accept-package-agreements --accept-source-agreements }
                "VLC" { winget install --id VideoLAN.VLC --silent --accept-package-agreements --accept-source-agreements }
            }
            if ($LASTEXITCODE -eq 0) { Write-Log "  ✓ Instalado: $app" "OK" } 
            else { Write-Log "  ✗ Error: $app" "WARN" }
        } catch { Write-Log "  ✗ Error: $_" "ERROR" }
        [System.Windows.Forms.Application]::DoEvents()
    }
    Write-Log "========== INSTALACION COMPLETADA ==========" "OK"
    $global:InstallRunning = $false
}
#endregion

