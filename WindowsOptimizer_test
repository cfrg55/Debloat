#region [FUNCIONES DE DEBLOAT]
function Remove-AllBloatware {
    Write-Log "========== ELIMINANDO BLOATWARE ==========" "TASK"
    $removed = 0
    $failed = 0
    
    Write-Log "Paso 1: Eliminando paquetes de usuario..." "INFO"
    $userPackages = Get-AppxPackage | Where-Object { $_.Name -match $global:BloatwareRegex }
    foreach ($pkg in $userPackages) {
        try {
            Remove-AppxPackage -Package $pkg -EA 0
            $removed++
            Write-Log "  ✓ Eliminado: $($pkg.Name)" "OK"
        } catch {
            $failed++
            Write-Log "  ✗ Error: $($pkg.Name)" "WARN"
        }
    }
    
    Write-Log "Paso 2: Eliminando paquetes provisionados..." "INFO"
    $provisionedPackages = Get-AppxProvisionedPackage -Online | Where-Object { $_.DisplayName -match $global:BloatwareRegex }
    foreach ($pkg in $provisionedPackages) {
        try {
            Remove-AppxProvisionedPackage -Online -PackageName $pkg.PackageName -EA 0
            $removed++
            Write-Log "  ✓ Eliminado provisionado: $($pkg.DisplayName)" "OK"
        } catch {
            $failed++
            Write-Log "  ✗ Error: $($pkg.DisplayName)" "WARN"
        }
    }
    
    Write-Log "Paso 3: Desactivando telemetría y privacidad..." "INFO"
    $tp = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection"
    if (!(Test-Path $tp)) { New-Item $tp -Force | Out-Null }
    Set-ItemProperty $tp -Name "AllowTelemetry" -Value 0 -EA 0
    Write-Log "  ✓ Telemetría desactivada" "OK"
    
    $bp = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Search"
    if (!(Test-Path $bp)) { New-Item $bp -Force | Out-Null }
    Set-ItemProperty $bp -Name "BingSearchEnabled" -Value 0 -EA 0
    Write-Log "  ✓ Bing Search desactivado" "OK"
    
    $cp = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search"
    if (!(Test-Path $cp)) { New-Item $cp -Force | Out-Null }
    Set-ItemProperty $cp -Name "AllowCortana" -Value 0 -EA 0
    Write-Log "  ✓ Cortana desactivada" "OK"
    
    if ($global:IsWindows11) {
        $wp = "HKLM:\SOFTWARE\Policies\Microsoft\Dsh"
        if (!(Test-Path $wp)) { New-Item $wp -Force | Out-Null }
        Set-ItemProperty $wp -Name "AllowNewsAndInterests" -Value 0 -EA 0
        Write-Log "  ✓ News & Interests desactivado" "OK"
    }
    
    if ($global:Is24H2) {
        $rp = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\System"
        if (!(Test-Path $rp)) { New-Item $rp -Force | Out-Null }
        Set-ItemProperty $rp -Name "EnableRecall" -Value 0 -EA 0
        Write-Log "  ✓ Recall desactivado" "OK"
    }
    
    Write-Log "========== COMPLETADO: $removed apps eliminadas, $failed fallidas ==========" "OK"
}

function Disable-Copilot {
    Write-Log "========== DESACTIVANDO COPILOT ==========" "TASK"
    
    if (-not $global:IsWindows11) {
        Write-Log "Copilot solo existe en Windows 11. No hay nada que desactivar." "WARN"
        Write-Log "========== COMPLETADO ==========" "OK"
        return
    }
    
    $removed = 0
    $failed = 0
    
    Write-Log "Paso 1: Deteniendo procesos de Copilot..." "INFO"
    Get-Process -Name "*copilot*" -EA 0 | Stop-Process -Force -EA 0
    Write-Log "  ✓ Procesos detenidos" "OK"
    
    Write-Log "Paso 2: Eliminando paquetes de Copilot del usuario..." "INFO"
    $copilotUserPackages = Get-AppxPackage | Where-Object { 
        $_.Name -match "Copilot|Microsoft.Windows.AI.Copilot|Microsoft.Copilot|Windows.AI" 
    }
    foreach ($pkg in $copilotUserPackages) {
        try {
            Remove-AppxPackage -Package $pkg -EA 0
            $removed++
            Write-Log "  ✓ Eliminado: $($pkg.Name)" "OK"
        } catch {
            $failed++
            Write-Log "  ✗ Error: $($pkg.Name)" "WARN"
        }
    }
    
    Write-Log "Paso 3: Eliminando paquetes provisionados de Copilot..." "INFO"
    $copilotProvisioned = Get-AppxProvisionedPackage -Online | Where-Object { 
        $_.DisplayName -match "Copilot|Microsoft.Windows.AI.Copilot|Microsoft.Copilot|Windows.AI" 
    }
    foreach ($pkg in $copilotProvisioned) {
        try {
            Remove-AppxProvisionedPackage -Online -PackageName $pkg.PackageName -EA 0
            $removed++
            Write-Log "  ✓ Eliminado provisionado: $($pkg.DisplayName)" "OK"
        } catch {
            $failed++
            Write-Log "  ✗ Error: $($pkg.DisplayName)" "WARN"
        }
    }
    
    Write-Log "Paso 4: Desactivando Copilot en el registro..." "INFO"
    $copilotRegPaths = @(
        @{Path="HKCU:\Software\Microsoft\Windows\CurrentVersion\Copilot"; Name="TurnOffWindowsCopilot"; Value=1},
        @{Path="HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot"; Name="TurnOffWindowsCopilot"; Value=1},
        @{Path="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"; Name="ShowCopilotButton"; Value=0},
        @{Path="HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Copilot"; Name="TurnOffWindowsCopilot"; Value=1}
    )
    foreach ($reg in $copilotRegPaths) {
        try {
            if (!(Test-Path $reg.Path)) { New-Item $reg.Path -Force | Out-Null }
            Set-ItemProperty -Path $reg.Path -Name $reg.Name -Value $reg.Value -EA 0
            Write-Log "  ✓ Desactivado: $($reg.Name)=$($reg.Value)" "OK"
        } catch {
            Write-Log "  ✗ Error en registro: $($reg.Path)" "WARN"
        }
    }
    
    Write-Log "Paso 5: Limpiando archivos de Copilot..." "INFO"
    $copilotPaths = @(
        "$env:LOCALAPPDATA\Microsoft\Copilot",
        "$env:APPDATA\Microsoft\Copilot",
        "$env:LOCALAPPDATA\Packages\*Copilot*",
        "$env:APPDATA\Packages\*Copilot*"
    )
    foreach ($path in $copilotPaths) {
        try {
            if (Test-Path $path) {
                Remove-Item -Path $path -Recurse -Force -EA 0
                Write-Log "  ✓ Eliminado: $path" "OK"
            }
        } catch {
            Write-Log "  ✗ Error al eliminar: $path" "WARN"
        }
    }
    
    Write-Log "Paso 6: Reiniciando explorador para aplicar cambios..." "INFO"
    try {
        Stop-Process -Name explorer -Force -EA 0
        Start-Sleep -Seconds 3
        Start-Process explorer.exe
        Write-Log "  ✓ Explorador reiniciado" "OK"
    } catch {
        Write-Log "  ✗ Error al reiniciar explorador" "WARN"
    }
    
    Write-Log "========== COMPLETADO: $removed elementos eliminados, $failed fallidos ==========" "OK"
    Write-Log "NOTA: Se recomienda reiniciar el sistema para aplicar todos los cambios." "INFO"
}
#endregion

#region [FUNCIONES DE INSTALACIÓN]
function Remove-OneDrive {
    Write-Log "========== DESINSTALANDO ONEDRIVE ==========" "TASK"
    try {
        Get-Process "OneDrive*" -EA 0 | Stop-Process -Force
        $uninstaller = "$env:SYSTEMROOT\SysWOW64\OneDriveSetup.exe"
        if (!(Test-Path $uninstaller)) { $uninstaller = "$env:SYSTEMROOT\System32\OneDriveSetup.exe" }
        if (Test-Path $uninstaller) {
            Write-Log "Ejecutando desinstalador..." "INFO"
            Start-Process $uninstaller "/uninstall" -NoNewWindow -Wait
            Write-Log "  ✓ OneDrive desinstalado" "OK"
        } else { Write-Log "  ✗ Desinstalador no encontrado" "WARN" }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Install-OneDrive {
    Write-Log "========== INSTALANDO ONEDRIVE ==========" "TASK"
    $installer = "$global:DownloadDir\OneDriveSetup.exe"
    try {
        Write-Log "Descargando instalador..." "INFO"
        Invoke-WebRequest -Uri "https://go.microsoft.com/fwlink/?linkid=844652" -OutFile $installer -UseBasicParsing
        if ((Get-Item $installer -EA 0).Length -gt 1MB) {
            Write-Log "Ejecutando instalador..." "INFO"
            Start-Process $installer "/silent" -Wait
            Write-Log "  ✓ OneDrive instalado correctamente" "OK"
        } else { throw "Archivo descargado no válido" }
    } catch { Write-Log "Error: $_" "ERROR" }
    finally { if (Test-Path $installer) { Remove-Item $installer -Force -EA 0 } }
    Write-Log "========== COMPLETADO ==========" "OK"
}

