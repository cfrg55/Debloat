function Install-SelectedApps {
    param([string[]]$Apps)
    if ($global:InstallRunning) { Write-Log "Ya hay una instalacion en curso" "WARN"; return }
    $global:InstallRunning = $true
    Write-Log "========== INSTALANDO APLICACIONES ==========" "TASK"
    if (-not $global:WingetAvailable) { Write-Log "Winget no disponible" "WARN"; $global:InstallRunning = $false; return }
    
    foreach ($app in $Apps) {
        Write-Log "Instalando: $app..." "INFO"
        try {
            switch ($app) {
                "7zip" { winget install --id 7zip.7zip --silent --accept-package-agreements --accept-source-agreements }
                "Chrome" { 
                    $tempDir = "C:\ChromeTemp"
                    New-Item -ItemType Directory -Force -Path $tempDir | Out-Null
                    $env:TEMP = $tempDir
                    $env:TMP = $tempDir
                    winget install --id Google.Chrome --silent --accept-package-agreements --accept-source-agreements
                    Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue 
                }
                "Firefox" { winget install --id Mozilla.Firefox --silent --accept-package-agreements --accept-source-agreements }
                "VLC" { winget install --id VideoLAN.VLC --silent --accept-package-agreements --accept-source-agreements }
            }
            if ($LASTEXITCODE -eq 0) { Write-Log "  ✓ Instalado: $app" "OK" } 
            else { Write-Log "  ✗ Error: $app (Código: $LASTEXITCODE)" "WARN" }
        } catch { Write-Log "  ✗ Error: $_" "ERROR" }
        [System.Windows.Forms.Application]::DoEvents()
    }
    Write-Log "========== INSTALACION COMPLETADA ==========" "OK"
    $global:InstallRunning = $false
}
#endregion

#region [FUNCIONES DE SISTEMA]
function Optimize-System {
    Write-Log "========== OPTIMIZANDO SISTEMA ==========" "TASK"
    
    Write-Log "Ajustando configuración de rendimiento..." "INFO"
    $pp = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile"
    if (!(Test-Path $pp)) { New-Item $pp -Force | Out-Null }
    Set-ItemProperty $pp -Name "SystemResponsiveness" -Value 10 -EA 0
    Write-Log "  ✓ SystemResponsiveness ajustado" "OK"
    
    Write-Log "Deshabilitando servicios innecesarios..." "INFO"
    $services = @("SysMain", "WSearch")
    foreach ($svc in $services) {
        try {
            Stop-Service $svc -Force -EA 0
            Set-Service $svc -StartupType Disabled -EA 0
            Write-Log "  ✓ Servicio deshabilitado: $svc" "OK"
        } catch {
            Write-Log "  ✗ Error deshabilitando: $svc" "WARN"
        }
    }
    
    Write-Log "Activando plan de alto rendimiento..." "INFO"
    try {
        powercfg -setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c 2>&1 | Out-Null
        Write-Log "  ✓ Plan de alto rendimiento activado" "OK"
    } catch {
        Write-Log "  ✗ Error activando plan de alto rendimiento" "WARN"
    }
    
    Write-Log "========== OPTIMIZACION COMPLETADA ==========" "OK"
}

function Repair-System {
    Write-Log "========== REPARANDO SISTEMA ==========" "TASK"
    
    function Invoke-LongCommand {
        param($Command, $Arguments, $StepName)
        Write-Log "[$StepName] Ejecutando..." "INFO"
        $process = Start-Process -FilePath $Command -ArgumentList $Arguments -NoNewWindow -PassThru
        $elapsed = 0
        while (-not $process.HasExited) {
            Start-Sleep -Seconds 5
            $elapsed += 5
            Write-Log "[$StepName] En progreso... ($elapsed segundos)" "INFO"
        }
        $process.WaitForExit()
        Write-Log "[$StepName] Completado. Código: $($process.ExitCode)" "OK"
    }

    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /CheckHealth" "DISM CheckHealth"
    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /ScanHealth" "DISM ScanHealth"
    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /RestoreHealth" "DISM RestoreHealth"
    Invoke-LongCommand "sfc.exe" "/scannow" "SFC Scannow"
    Write-Log "========== REPARACION COMPLETADA ==========" "OK"
}

function Reset-WindowsUpdate {
    Write-Log "========== REINICIANDO WINDOWS UPDATE ==========" "TASK"
    Write-Log "Deteniendo servicios..." "INFO"
    @("bits", "wuauserv", "appidsvc", "cryptsvc") | ForEach-Object { 
        Stop-Service $_ -Force -EA 0
        Write-Log "  ✓ $_ detenido" "OK"
    }
    Write-Log "Limpiando cache..." "INFO"
    @("$env:SystemRoot\SoftwareDistribution", "$env:SystemRoot\system32\catroot2") | ForEach-Object { 
        if (Test-Path $_) { 
            Remove-Item "$_\*" -Recurse -Force -EA 0
            Write-Log "  ✓ $_ limpiado" "OK"
        }
    }
    Write-Log "Reiniciando servicios..." "INFO"
    @("bits", "wuauserv", "appidsvc", "cryptsvc") | ForEach-Object { 
        Start-Service $_ -EA 0
        Write-Log "  ✓ $_ iniciado" "OK"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Create-RestorePoint {
    Write-Log "========== CREANDO PUNTO DE RESTAURACION ==========" "TASK"
    try {
        Checkpoint-Computer -Description "Windows Optimizer - Antes de cambios" -EA 0
        Write-Log "  ✓ Punto de restauracion creado exitosamente" "OK"
    } catch { Write-Log "  ✗ No se pudo crear punto de restauracion" "WARN" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Kill-HungProcesses {
    Write-Log "========== TERMINANDO PROCESOS BLOQUEADOS ==========" "TASK"
    if ($global:RepairTimer -ne $null) { $global:RepairTimer.Stop(); $global:RepairTimer.Dispose(); $global:RepairTimer = $null }
    if ($global:CurrentJob -ne $null) { Stop-Job $global:CurrentJob -EA 0; Remove-Job $global:CurrentJob -Force -EA 0; $global:CurrentJob = $null; $global:RepairRunning = $false }
    $procs = @("dism", "sfc", "TiWorker", "TrustedInstaller", "OneDriveSetup", "winget", "copilot", "explorer")
    $killed = 0
    foreach ($proc in $procs) {
        try {
            Get-Process -Name $proc -EA 0 | Stop-Process -Force -EA 0 | Out-Null
            $killed++
            Write-Log "  ✓ Terminado: $proc" "OK"
        } catch {
            Write-Log "  ✗ No encontrado: $proc" "INFO"
        }
    }
    Write-Log "========== COMPLETADO: $killed procesos terminados ==========" "OK"
}
