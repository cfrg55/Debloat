# Función para auto-elevarse (funciona con rutas UNC)
function Test-AdminElevation {
    $currentPrincipal = [Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()
    $isAdmin = $currentPrincipal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
    
    if (-not $isAdmin) {
        Write-Host "Se requieren privilegios de administrador. Solicitando elevacion..." -ForegroundColor Yellow
        
        # Obtener la ruta del script actual
        $scriptPath = $PSCommandPath
        if (-not $scriptPath -or $scriptPath -eq "") {
            $scriptPath = $MyInvocation.MyCommand.Definition
        }
        
        # Para rutas UNC, necesitamos copiar el script localmente primero
        $isUncPath = $scriptPath -like "\\*"
        
        if ($isUncPath) {
            Write-Host "Detectada ejecucion desde ruta UNC. Copiando script a temporal local..." -ForegroundColor Cyan
            $localScript = "$env:TEMP\WindowsOptimizer_$(Get-Random).ps1"
            Copy-Item -Path $scriptPath -Destination $localScript -Force
            $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$localScript`""
            $process = Start-Process -FilePath "PowerShell.exe" -ArgumentList $arguments -Verb RunAs -PassThru
            $process.WaitForExit()
            # Limpiar archivo temporal
            Start-Sleep -Seconds 2
            Remove-Item $localScript -Force -ErrorAction SilentlyContinue
        } else {
            $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$scriptPath`""
            $process = Start-Process -FilePath "PowerShell.exe" -ArgumentList $arguments -Verb RunAs -PassThru
            $process.WaitForExit()
        }
        exit
    }
    
    Write-Host "Ejecutando con privilegios de administrador..." -ForegroundColor Green
    return $true
}

