#region [FUNCIONES]
function Clear-CurrentUserTemp {
    Write-Log "========== LIMPIANDO PERFIL ACTUAL ==========" "TASK"
    try {
        if (Test-Path "$env:TEMP") {
            Get-ChildItem "$env:TEMP" -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
            Write-Log "Limpieza de Temp completada" "OK"
        }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-AllUsersTemp {
    Write-Log "========== LIMPIANDO TODOS LOS PERFILES ==========" "TASK"
    Get-ChildItem "C:\Users" -Directory -EA 0 | ForEach-Object {
        $userTemp = Join-Path $_.FullName "AppData\Local\Temp"
        if (Test-Path $userTemp) {
            Write-Log "Limpiando: $($_.Name)" "INFO"
            Get-ChildItem $userTemp -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        }
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-WindowsTemp {
    Write-Log "========== LIMPIANDO WINDOWS TEMP ==========" "TASK"
    if (Test-Path "C:\Windows\Temp") {
        Get-ChildItem "C:\Windows\Temp" -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        Write-Log "Limpieza completada" "OK"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-InternetCache {
    Write-Log "========== LIMPIANDO CACHE DE INTERNET ==========" "TASK"
    $cachePaths = @(
        "$env:LOCALAPPDATA\Microsoft\Windows\INetCache",
        "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Cache",
        "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Cache"
    )
    foreach ($path in $cachePaths) {
        if (Test-Path $path) {
            Write-Log "Limpiando: $path" "INFO"
            Get-ChildItem $path -Recurse -EA 0 | Where-Object { !$_.PSIsContainer } | Remove-Item -Force -EA 0
        }
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Run-DiskCleanup {
    Write-Log "========== EJECUTANDO LIMPIEZA DE DISCO ==========" "TASK"
    try {
        if (Get-Command cleanmgr.exe -ErrorAction SilentlyContinue) {
            cleanmgr.exe /sagerun:64 2>&1 | Out-Null
            Write-Log "Limpieza de disco completada" "OK"
        } else {
            Write-Log "cleanmgr.exe no encontrado" "WARN"
        }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Disable-Firewall {
    Write-Log "========== DESHABILITANDO FIREWALL ==========" "TASK"
    netsh advfirewall set domainprofile state off | Out-Null
    netsh advfirewall set privateprofile state off | Out-Null
    netsh advfirewall set publicprofile state off | Out-Null
    Write-Log "Firewall deshabilitado" "OK"
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Clear-WindowsUpdateCache {
    Write-Log "========== LIMPIANDO CACHE DE WINDOWS UPDATE ==========" "TASK"
    Write-Log "Deteniendo servicios..." "INFO"
    net stop bits /y | Out-Null
    net stop wuauserv /y | Out-Null
    net stop cryptsvc /y | Out-Null
    
    Write-Log "Limpiando carpetas..." "INFO"
    @("$env:SystemRoot\SoftwareDistribution", "$env:SystemRoot\system32\catroot2") | ForEach-Object {
        if (Test-Path $_) { 
            Remove-Item "$_\*" -Recurse -Force -EA 0
            Write-Log "  Limpiado: $_" "OK"
        }
    }
    
    Write-Log "Reiniciando servicios..." "INFO"
    net start bits | Out-Null
    net start wuauserv | Out-Null
    net start cryptsvc | Out-Null
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Invoke-FullCleanup {
    Write-Log "========== LIMPIEZA COMPLETA ==========" "TASK"
    Clear-CurrentUserTemp
    Clear-AllUsersTemp
    Clear-WindowsTemp
    Clear-InternetCache
    Run-DiskCleanup
    Clear-WindowsUpdateCache
    Write-Log "========== LIMPIEZA COMPLETA FINALIZADA ==========" "OK"
}

function Remove-AllBloatware {
    Write-Log "========== ELIMINANDO BLOATWARE ==========" "TASK"
    $removed = 0
    Get-AppxPackage | Where-Object { $_.Name -match $global:BloatwareRegex } | ForEach-Object {
        Remove-AppxPackage -Package $_ -EA 0
        $removed++
        Write-Log "  Eliminado: $($_.Name)" "OK"
    }
    Get-AppxProvisionedPackage -Online | Where-Object { $_.DisplayName -match $global:BloatwareRegex } | ForEach-Object {
        Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -EA 0
    }
    
    Write-Log "Aplicando optimizaciones de privacidad..." "INFO"
    $tp = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection"
    if (!(Test-Path $tp)) { New-Item $tp -Force | Out-Null }
    Set-ItemProperty $tp -Name "AllowTelemetry" -Value 0 -EA 0
    
    $bp = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Search"
    if (!(Test-Path $bp)) { New-Item $bp -Force | Out-Null }
    Set-ItemProperty $bp -Name "BingSearchEnabled" -Value 0 -EA 0
    
    $cp = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search"
    if (!(Test-Path $cp)) { New-Item $cp -Force | Out-Null }
    Set-ItemProperty $cp -Name "AllowCortana" -Value 0 -EA 0
    
    if ($global:IsWindows11) {
        $wp = "HKLM:\SOFTWARE\Policies\Microsoft\Dsh"
        if (!(Test-Path $wp)) { New-Item $wp -Force | Out-Null }
        Set-ItemProperty $wp -Name "AllowNewsAndInterests" -Value 0 -EA 0
    }
    if ($global:Is24H2) {
        $rp = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\System"
        if (!(Test-Path $rp)) { New-Item $rp -Force | Out-Null }
        Set-ItemProperty $rp -Name "EnableRecall" -Value 0 -EA 0
    }
    Write-Log "========== COMPLETADO: $removed apps eliminadas ==========" "OK"
}

function Remove-OneDrive {
    Write-Log "========== DESINSTALANDO ONEDRIVE ==========" "TASK"
    try {
        Get-Process "OneDrive*" -EA 0 | Stop-Process -Force
        $uninstaller = "$env:SYSTEMROOT\SysWOW64\OneDriveSetup.exe"
        if (!(Test-Path $uninstaller)) { $uninstaller = "$env:SYSTEMROOT\System32\OneDriveSetup.exe" }
        if (Test-Path $uninstaller) {
            Write-Log "Ejecutando desinstalador..." "INFO"
            Start-Process $uninstaller "/uninstall" -NoNewWindow -Wait
            Write-Log "OneDrive desinstalado" "OK"
        } else { Write-Log "Desinstalador no encontrado" "WARN" }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Install-OneDrive {
    Write-Log "========== INSTALANDO ONEDRIVE ==========" "TASK"
    $installer = "$global:DownloadDir\OneDriveSetup.exe"
    try {
        Write-Log "Descargando instalador..." "INFO"
        Invoke-WebRequest -Uri "https://go.microsoft.com/fwlink/?linkid=844652" -OutFile $installer -UseBasicParsing
        if ((Get-Item $installer -EA 0).Length -gt 1MB) {
            Write-Log "Ejecutando instalador..." "INFO"
            Start-Process $installer "/silent" -Wait
            Write-Log "OneDrive instalado correctamente" "OK"
        } else { throw "Archivo descargado no válido" }
    } catch { Write-Log "Error: $_" "ERROR" }
    finally { if (Test-Path $installer) { Remove-Item $installer -Force -EA 0 } }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Install-Teams {
    Write-Log "========== INSTALANDO MICROSOFT TEAMS ==========" "TASK"
    if (-not $global:WingetAvailable) { 
        Write-Log "Winget no disponible. Abriendo página de descarga..." "WARN"
        Start-Process "https://www.microsoft.com/es-mx/microsoft-teams/download-app"
        return
    }
    try {
        winget install --id Microsoft.Teams --exact --accept-package-agreements --accept-source-agreements --silent
        if ($LASTEXITCODE -eq 0) { Write-Log "Teams instalado correctamente" "OK" } 
        else { Write-Log "Error en instalación. Código: $LASTEXITCODE" "WARN" }
    } catch { Write-Log "Error: $_" "ERROR" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Install-SelectedApps {
    param([string[]]$Apps)
    if ($global:InstallRunning) { Write-Log "Ya hay una instalacion en curso" "WARN"; return }
    $global:InstallRunning = $true
    Write-Log "========== INSTALANDO APLICACIONES ==========" "TASK"
    if (-not $global:WingetAvailable) { Write-Log "Winget no disponible" "WARN"; $global:InstallRunning = $false; return }
    
    foreach ($app in $Apps) {
        Write-Log "Instalando: $app..." "INFO"
        try {
            switch ($app) {
                "7zip" { winget install --id 7zip.7zip --silent --accept-package-agreements --accept-source-agreements }
                "Chrome" { #winget install --id Google.Chrome --silent --accept-package-agreements --accept-source-agreements
                            # 1. Crear carpeta temporal
                            $tempDir = "C:\ChromeTemp"
                            New-Item -ItemType Directory -Force -Path $tempDir | Out-Null

                            # 2. Establecer variables de entorno para toda la sesión
                            $env:TEMP = $tempDir
                            $env:TMP = $tempDir

                            # 3. Ejecutar winget con estas variables
                            winget install --id Google.Chrome --silent --accept-package-agreements --accept-source-agreements

                            # 4. Limpiar (opcional)
                            Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue }
                "Firefox" { winget install --id Mozilla.Firefox --silent --accept-package-agreements --accept-source-agreements }
                "VLC" { winget install --id VideoLAN.VLC --silent --accept-package-agreements --accept-source-agreements }
            }
            if ($LASTEXITCODE -eq 0) { Write-Log "  Instalado: $app" "OK" } 
            else { Write-Log "  Error instalando: $app (Código: $LASTEXITCODE)" "WARN" }
        } catch { Write-Log "  Error: $_" "ERROR" }
        [System.Windows.Forms.Application]::DoEvents()
    }
    Write-Log "========== INSTALACION COMPLETADA ==========" "OK"
    $global:InstallRunning = $false
}

function Optimize-System {
    Write-Log "========== OPTIMIZANDO SISTEMA ==========" "TASK"
    $pp = "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile"
    if (!(Test-Path $pp)) { New-Item $pp -Force | Out-Null }
    Set-ItemProperty $pp -Name "SystemResponsiveness" -Value 10 -EA 0
    @("SysMain", "WSearch") | ForEach-Object { 
        Stop-Service $_ -Force -EA 0
        Set-Service $_ -StartupType Disabled -EA 0
        Write-Log "Servicio deshabilitado: $_" "OK"
    }
    powercfg -setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c 2>&1 | Out-Null
    Write-Log "Plan de alto rendimiento activado" "OK"
    Write-Log "========== OPTIMIZACION COMPLETADA ==========" "OK"
}

function Repair-System {
    Write-Log "========== REPARANDO SISTEMA ==========" "TASK"
    
    function Invoke-LongCommand {
        param($Command, $Arguments, $StepName)
        Write-Log "[$StepName] Ejecutando..." "INFO"
        $process = Start-Process -FilePath $Command -ArgumentList $Arguments -NoNewWindow -PassThru
        $elapsed = 0
        while (-not $process.HasExited) {
            Start-Sleep -Seconds 5
            $elapsed += 5
            Write-Log "[$StepName] En progreso... ($elapsed segundos)" "INFO"
        }
        $process.WaitForExit()
        Write-Log "[$StepName] Completado. Código: $($process.ExitCode)" "OK"
    }

    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /CheckHealth" "DISM CheckHealth"
    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /ScanHealth" "DISM ScanHealth"
    Invoke-LongCommand "dism.exe" "/Online /Cleanup-Image /RestoreHealth" "DISM RestoreHealth"
    Invoke-LongCommand "sfc.exe" "/scannow" "SFC Scannow"
    Write-Log "========== REPARACION COMPLETADA ==========" "OK"
}

function Reset-WindowsUpdate {
    Write-Log "========== REINICIANDO WINDOWS UPDATE ==========" "TASK"
    Write-Log "Deteniendo servicios..." "INFO"
    @("bits", "wuauserv", "appidsvc", "cryptsvc") | ForEach-Object { 
        Stop-Service $_ -Force -EA 0
        Write-Log "  $_ detenido" "OK"
    }
    Write-Log "Limpiando cache..." "INFO"
    @("$env:SystemRoot\SoftwareDistribution", "$env:SystemRoot\system32\catroot2") | ForEach-Object { 
        if (Test-Path $_) { 
            Remove-Item "$_\*" -Recurse -Force -EA 0
            Write-Log "  $_ limpiado" "OK"
        }
    }
    Write-Log "Reiniciando servicios..." "INFO"
    @("bits", "wuauserv", "appidsvc", "cryptsvc") | ForEach-Object { 
        Start-Service $_ -EA 0
        Write-Log "  $_ iniciado" "OK"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Create-RestorePoint {
    Write-Log "========== CREANDO PUNTO DE RESTAURACION ==========" "TASK"
    try {
        Checkpoint-Computer -Description "Windows Optimizer - Antes de cambios" -EA 0
        Write-Log "Punto de restauracion creado exitosamente" "OK"
    } catch { Write-Log "No se pudo crear punto de restauracion" "WARN" }
    Write-Log "========== COMPLETADO ==========" "OK"
}

function Kill-HungProcesses {
    Write-Log "========== TERMINANDO PROCESOS BLOQUEADOS ==========" "TASK"
    if ($global:RepairTimer -ne $null) { $global:RepairTimer.Stop(); $global:RepairTimer.Dispose(); $global:RepairTimer = $null }
    if ($global:CurrentJob -ne $null) { Stop-Job $global:CurrentJob -EA 0; Remove-Job $global:CurrentJob -Force -EA 0; $global:CurrentJob = $null; $global:RepairRunning = $false }
    $procs = @("dism", "sfc", "TiWorker", "TrustedInstaller", "OneDriveSetup", "winget")
    foreach ($proc in $procs) {
        Get-Process -Name $proc -EA 0 | Stop-Process -Force -EA 0 | Out-Null
        Write-Log "  Terminado: $proc" "OK"
    }
    Write-Log "========== COMPLETADO ==========" "OK"
}
